{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "6002455545741476231"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "australiaeast"
    },
    "environment": {
      "type": "string",
      "defaultValue": "test"
    }
  },
  "variables": {
    "workspaceName": "[format('log-{0}', uniqueString(resourceGroup().id))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2021-12-01-preview",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30,
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled",
        "features": {
          "searchVersion": 1,
          "legacy": 0,
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      },
      "tags": {
        "environment": "[parameters('environment')]",
        "managed": "true",
        "purpose": "drift-detection-test"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/tables",
      "apiVersion": "2021-12-01-preview",
      "name": "[format('{0}/{1}', variables('workspaceName'), 'CustomLog_CL')]",
      "properties": {
        "totalRetentionInDays": 30,
        "plan": "Analytics",
        "schema": {
          "name": "CustomLog_CL",
          "columns": [
            {
              "name": "TimeGenerated",
              "type": "datetime"
            },
            {
              "name": "Message_s",
              "type": "string"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    }
  ],
  "outputs": {
    "workspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
    },
    "workspaceName": {
      "type": "string",
      "value": "[variables('workspaceName')]"
    },
    "workspaceResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), '2021-12-01-preview').customerId]"
    },
    "workspaceSkuName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), '2021-12-01-preview').sku.name]"
    }
  }
}